# ====== FILL ALL VALUES BEFORE RUNNING ======
# This file documents every credential needed by both the frontend and backend.
# Copy the relevant sections into frontend/.env.local and backend/.env

# ---------- Supabase ----------
# Get from: https://supabase.com  ->  your project  ->  Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ---------- Telegram API ----------
# Get from: https://my.telegram.org  ->  API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ---------- Session Encryption ----------
# Generate a 32-byte base64 key:  python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
SESSION_ENCRYPTION_KEY=

# ---------- Backend URL ----------
# Local dev: http://localhost:8000
# Production: https://<your-render-service>.onrender.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ---------- GitHub Actions cron secret ----------
# Any long random string; used to authorize the daily /scrape/all call.
CRON_SECRET=

# ---------- Google OAuth (configured inside Supabase dashboard) ----------
# No env var needed here. Configure under:
# Supabase -> Authentication -> Providers -> Google
# Use Google Cloud Console to create OAuth client, add redirect URL from Supabase.
